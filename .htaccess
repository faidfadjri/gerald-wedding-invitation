<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Semua request ke public
    RewriteCond %{REQUEST_URI} !^public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php [L]

    # Default index
    DirectoryIndex public/index.php
</IfModule>
